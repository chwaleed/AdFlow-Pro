NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/adflow

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=adflow-media

# Cron job auth (for manual-trigger endpoints)
CRON_SECRET=change_this_to_another_random_secret
