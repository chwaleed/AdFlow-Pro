{
  "name": "adflow",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "concurrently \"pnpm --dir server dev\" \"pnpm --dir client dev\"",
    "dev:server": "pnpm --dir server dev",
    "dev:client": "pnpm --dir client dev",
    "install:all": "pnpm --dir server install && pnpm --dir client install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
